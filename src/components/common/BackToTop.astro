---
import { Icon } from 'astro-icon/components';
---

<button
  id="back-to-top"
  class="fixed bottom-6 right-6 z-50 p-3 rounded-full bg-emerald-500 text-white shadow-lg hover:bg-emerald-600 hover:-translate-y-1 transition-all duration-300 opacity-0 pointer-events-none focus:outline-none focus:ring-4 focus:ring-emerald-300 dark:focus:ring-emerald-800"
  aria-label="Retour en haut de page"
  title="Retour en haut"
>
  <Icon name="tabler:arrow-up" class="w-6 h-6" />
</button>

<script>
  let lastTimeout: ReturnType<typeof setTimeout>;

  const initBackToTop = () => {
    const btn = document.getElementById('back-to-top');

    if (!btn) return;

    // Remove old listeners to avoid duplicates on View Transitions
    const newBtn = btn.cloneNode(true) as HTMLElement;
    btn.parentNode?.replaceChild(newBtn, btn);

    const toggleVisibility = () => {
      if (window.scrollY > 300) {
        newBtn.classList.remove('opacity-0', 'pointer-events-none');
        newBtn.classList.add('opacity-100');
      } else {
        newBtn.classList.add('opacity-0', 'pointer-events-none');
        newBtn.classList.remove('opacity-100');
      }
    };

    window.addEventListener('scroll', () => {
      if (lastTimeout) clearTimeout(lastTimeout);
      lastTimeout = setTimeout(toggleVisibility, 50);
    });

    newBtn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // Initial check
    toggleVisibility();
  };

  // Run on first load
  initBackToTop();

  // Run on Astro View Transitions
  document.addEventListener('astro:page-load', initBackToTop);
</script>
