---
// ExcelWorkflow — Logo SVG minimaliste
---

<a href="/" class="flex items-center gap-2 group" aria-label="ExcelWorkflow — Accueil">
  <!-- SVG Logo minimaliste : grille + éclair -->
  <svg
    width="36"
    height="36"
    viewBox="0 0 36 36"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class="shrink-0 transition-transform duration-300 group-hover:scale-110"
    aria-hidden="true"
  >
    <!-- Fond rond dégradé -->
    <rect width="36" height="36" rx="8" fill="#0F172A"/>
    <!-- Grille gauche -->
    <rect x="5" y="7" width="10" height="10" rx="1.5" fill="#10B981" opacity="0.25"/>
    <rect x="5" y="19" width="10" height="10" rx="1.5" fill="#10B981" opacity="0.15"/>
    <!-- Grille droite -->
    <rect x="17" y="19" width="14" height="10" rx="1.5" fill="#10B981" opacity="0.15"/>
    <!-- Éclair central -->
    <path
      d="M22 5L15 19h6l-2 12 10-16h-6L22 5Z"
      fill="#10B981"
      stroke="#34D399"
      stroke-width="0.5"
    />
  </svg>
  <span class="self-center text-xl font-extrabold tracking-tight whitespace-nowrap text-gray-900 dark:text-white leading-none">
    Excel<span class="text-emerald-500">Workflow</span>
  </span>
</a>
