---
import '@fontsource-variable/inter';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    /* ExcelWorkflow Brand Colors — Emerald + Dark Slate */
    --aw-color-primary: rgb(16 185 129);       /* Emerald 500 */
    --aw-color-secondary: rgb(5 150 105);      /* Emerald 600 */
    --aw-color-accent: rgb(52 211 153);        /* Emerald 400 */

    --aw-color-text-heading: rgb(15 23 42);    /* Slate 900 */
    --aw-color-text-default: rgb(30 41 59);    /* Slate 800 */
    --aw-color-text-muted: rgb(71 85 105);     /* Slate 500 */
    --aw-color-bg-page: rgb(248 250 252);      /* Slate 50 */

    --aw-color-bg-page-dark: rgb(2 6 23);      /* Near black */

    ::selection {
      background-color: rgb(167 243 208);      /* Emerald 200 */
      color: rgb(6 78 59);                     /* Emerald 900 */
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(16 185 129);       /* Emerald 500 */
    --aw-color-secondary: rgb(52 211 153);     /* Emerald 400 */
    --aw-color-accent: rgb(110 231 183);       /* Emerald 300 */

    --aw-color-text-heading: rgb(248 250 252); /* Slate 50 */
    --aw-color-text-default: rgb(226 232 240); /* Slate 200 */
    --aw-color-text-muted: rgb(148 163 184);   /* Slate 400 */
    --aw-color-bg-page: rgb(2 6 23);           /* Near black */

    ::selection {
      background-color: rgb(6 78 59);
      color: rgb(167 243 208);
    }
  }
</style>
